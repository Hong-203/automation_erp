# ============================================================
# config.properties.example
# Sao chép file này thành config.properties và điền giá trị thật
# KHÔNG commit file config.properties lên git
# ============================================================

base.url=https://your-app-url.com
api.base.url=https://your-app-url.com/api/v1

# Token tĩnh (tùy chọn — hiện tại framework dùng AuthManager nên có thể bỏ trống)
auth.token=

execution.type=API

# Health check mock flags
api.mock=false
ui.mock=false

# Browser config
browser=chrome
headless=true
timeout.seconds=15

# Tài khoản admin
admin.username=YOUR_ADMIN_USERNAME
admin.password=YOUR_ADMIN_PASSWORD

# Tài khoản staff
staff.username=YOUR_STAFF_USERNAME
staff.password=YOUR_STAFF_PASSWORD
